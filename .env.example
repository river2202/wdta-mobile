# Vercel Postgres (Neon) — copy from Vercel Dashboard → Storage → your DB → .env.local
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Secret used to authenticate Vercel Cron calls — set in Vercel Dashboard → Settings → Environment Variables
CRON_SECRET=

# Your Buy Me a Coffee page URL (shown in the results page footer)
NEXT_PUBLIC_BUYMEACOFFEE_URL=https://www.buymeacoffee.com/yourhandle
